}

function fullQty(item){
  if(item.trackMode === 'percent') return 100;
  const t = Number(item.threshold) || 0;
  return Math.max(item.full || 0, t * 2, Number(item.current) || 0, 1);
}

function ratio(item){
  const f = fullQty(item);
  return Math.max(0, Math.min(1, (Number(item.current)||0) / f));
}

function catMain(item){ return item.categoryMain || item.category || ''; }
function catSub(item){ return item.categorySub || ''; }
function catLabel(item){
  const m = catMain(item), s = catSub(item);
  if(m && s) return `${m} ／ ${s}`;
  return m || s || '';
}

function status(item){
  const cur = Number(item.current)||0;
  const t = Number(item.threshold)||0;
  if(cur <= t*0.5) return 'danger';
  if(cur <= t) return 'warn';
  return 'safe';
}

function statusLabel(s){
  return s === 'danger' ? '要発注' : s === 'warn' ? '要注意' : '在庫十分';
}

function statusColor(s){
  return s === 'danger' ? '#B23B3B' : s === 'warn' ? '#C98A2C' : '#3F7D53';
}

function gaugeSvg(item){
  const r = 22, c = 2*Math.PI*r;
  const pct = ratio(item);
  const color = statusColor(status(item));
  return `<svg width="52" height="52" viewBox="0 0 52 52">
    <circle cx="26" cy="26" r="${r}" fill="none" stroke="#DAD3BE" stroke-width="5"/>
    <circle cx="26" cy="26" r="${r}" fill="none" stroke="${color}" stroke-width="5"
      stroke-dasharray="${c}" stroke-dashoffset="${c*(1-pct)}" stroke-linecap="round"/>
  </svg>`;
}

function fmtDate(iso){
  if(!iso) return '';
  const d = new Date(iso);
  return `${d.getMonth()+1}/${d.getDate()} 更新`;
}

function expiryInfo(item){
  // 消費期限を優先し、無ければ賞味期限を見る
  const dateStr = item.useBy || item.bestBefore;
  if(!dateStr) return null;
  const label = item.useBy ? '消費期限' : '賞味期限';
  const target = new Date(dateStr + 'T00:00:00');
  if(isNaN(target.getTime())) return null;
  const today = new Date(); today.setHours(0,0,0,0);
  const days = Math.round((target - today) / 86400000);
  const warnDays = item.useBy ? 3 : 7;
  let level = 'ok';
  let text = `${label}: ${dateStr}`;
  if(days < 0){ level = 'danger'; text = `${label}切れ（${Math.abs(days)}日経過）`; }
  else if(days <= warnDays){ level = 'warn'; text = `${label}まで残り${days}日`; }
  return { level, text, days };
}

function render(){
  const search = document.getElementById('search').value.trim().toLowerCase();
  const catFilter = document.getElementById('filter-cat').value;
  const sortBy = document.getElementById('sort-by').value;

  const cats = [...new Set(items.map(i => catMain(i)).filter(Boolean))].sort();
  const catSelect = document.getElementById('filter-cat');
  const prevCat = catSelect.value;
  catSelect.innerHTML = '<option value="">すべての大分類</option>' +
    cats.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
  catSelect.value = cats.includes(prevCat) ? prevCat : '';
  document.getElementById('cat-main-list').innerHTML = cats.map(c => `<option value="${escapeHtml(c)}">`).join('');
  const subCats = [...new Set(items.map(i => catSub(i)).filter(Boolean))].sort();
  document.getElementById('cat-sub-list').innerHTML = subCats.map(c => `<option value="${escapeHtml(c)}">`).join('');

  let list = items.filter(i => {
    if(search && !i.name.toLowerCase().includes(search)) return false;
    if(catFilter && catMain(i) !== catFilter) return false;
    return true;
  });

  if(sortBy === 'urgent'){
    list.sort((a,b) => ratio(a) - ratio(b));
  }else if(sortBy === 'name'){
    list.sort((a,b) => a.name.localeCompare(b.name, 'ja'));
  }else if(sortBy === 'updated'){
    list.sort((a,b) => new Date(b.updatedAt||0) - new Date(a.updatedAt||0));
  }else if(sortBy === 'expiry'){
    list.sort((a,b) => {
      const da = a.useBy || a.bestBefore;
      const db = b.useBy || b.bestBefore;
      if(!da && !db) return 0;
      if(!da) return 1;
      if(!db) return -1;
      return new Date(da) - new Date(db);
    });
  }

  document.getElementById('sum-total').textContent = items.length;
  document.getElementById('sum-warn').textContent = items.filter(i => status(i)==='warn').length;
  document.getElementById('sum-danger').textContent = items.filter(i => status(i)==='danger').length;

  const grid = document.getElementById('grid');
  const empty = document.getElementById('empty');

  if(list.length === 0){
    grid.innerHTML = '';
    empty.style.display = 'block';
    empty.textContent = items.length === 0
      ? '登録された消耗品がありません。上のフォームから追加してください。'
      : '条件に一致する品目がありません。';
    renderShoppingList();
    return;
  }
  empty.style.display = 'none';

  grid.innerHTML = list.map(item => {
    const s = status(item);
    const pct = Math.round(ratio(item)*100);
    const exp = expiryInfo(item);
    const isPct = item.trackMode === 'percent';
    return `
    <div class="tag" data-id="${item.id}">
      <div class="tag-top">
        <div>
          <div class="tag-name">${escapeHtml(item.name)}</div>
          ${catLabel(item) ? `<span class="tag-cat">${escapeHtml(catLabel(item))}</span>` : ''}
        </div>
        <div class="gauge">${gaugeSvg(item)}<div class="gauge-pct">${pct}%</div></div>
      </div>
      ${isPct ? `
      <div class="tag-mid">
        <span class="cur">${Number(item.current)||0}</span>
        <span class="unit">%</span>
        <span class="thresh">発注ライン: ${Number(item.threshold)||0}%</span>
      </div>
      <div class="pct-slider-row">
        <input type="range" class="pct-slider" min="0" max="100" step="5" value="${Number(item.current)||0}">
        <span class="pct-val">${Number(item.current)||0}%</span>
      </div>
      ` : `
      <div class="tag-mid">
        <span class="cur">${Number(item.current)||0}</span>
        <span class="unit">${escapeHtml(item.unit||'')}</span>
        <span class="thresh">発注ライン: ${Number(item.threshold)||0}${escapeHtml(item.unit||'')}</span>
      </div>
      `}
      <span class="status-pill status-${s}">${statusLabel(s)}</span>
      ${exp ? `<span class="expiry-pill expiry-${exp.level}">${escapeHtml(exp.text)}</span>` : ''}
      <div class="tag-actions">
        ${isPct ? '<div></div>' : `
        <div class="qty-btns">
          <button data-act="dec" title="減らす">−</button>
          <button data-act="inc" title="増やす">＋</button>
        </div>
        `}
        <div class="edit-btns">
          <button data-act="edit">編集</button>
          <button data-act="del">削除</button>
        </div>
      </div>
      <div class="updated">${fmtDate(item.updatedAt)}</div>
    </div>`;
  }).join('');

  renderShoppingList();
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

