<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>在庫ノート - 日用品・消耗品管理</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700&family=JetBrains+Mono:wght@500;600&display=swap');

:root{
  --paper:#F2EFE4;
  --card:#FBFAF5;
  --ink:#2E2B22;
  --ink-sub:#7A755F;
  --line:#DAD3BE;
  --stamp:#B5451F;
  --safe:#3F7D53;
  --safe-bg:#E6F0E7;
  --warn:#C98A2C;
  --warn-bg:#F7EDDA;
  --danger:#B23B3B;
  --danger-bg:#F6E4E1;
}
*{box-sizing:border-box;}
body{
  margin:0;
  background:var(--paper);
  color:var(--ink);
  font-family:'Zen Kaku Gothic New', sans-serif;
  padding:32px 20px 80px;
}
.wrap{max-width:960px;margin:0 auto;}

header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  border-bottom:2px solid var(--ink);
  padding-bottom:14px;
  margin-bottom:24px;
}
header h1{
  font-size:24px;
  font-weight:700;
  margin:0;
  letter-spacing:0.02em;
}
header p{
  margin:4px 0 0;
  font-size:12.5px;
  color:var(--ink-sub);
}
.summary{
  display:flex;
  gap:18px;
  font-family:'JetBrains Mono',monospace;
  font-size:13px;
}
.summary div{text-align:right;}
.summary b{display:block;font-size:20px;font-weight:600;}
.summary .s-total b{color:var(--ink);}
.summary .s-warn b{color:var(--warn);}
.summary .s-danger b{color:var(--danger);}

.panel{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:6px;
  padding:18px 20px;
  margin-bottom:20px;
}
.panel h2{
  font-size:14px;
  font-weight:700;
  margin:0 0 12px;
  color:var(--ink);
}
.form-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(150px, 1fr));
  gap:10px;
  align-items:end;
}
.form-grid .btn-add{grid-column:1 / -1;justify-self:start;}
.field{display:flex;flex-direction:column;gap:4px;}
.field label{font-size:11px;color:var(--ink-sub);}
.field input, .field select{
  font-family:inherit;
  font-size:13.5px;
  padding:8px 9px;
  border:1px solid var(--line);
  border-radius:4px;
  background:#fff;
  color:var(--ink);
}
.field input:focus, .field select:focus{outline:2px solid var(--stamp);outline-offset:-1px;}
button{
  font-family:inherit;
  cursor:pointer;
}
.btn-add{
  background:var(--ink);
  color:var(--paper);
  border:none;
  border-radius:4px;
  padding:9px 16px;
  font-size:13.5px;
  font-weight:500;
  white-space:nowrap;
}
.btn-add:hover{background:#494533;}

.controls{
  display:flex;
  gap:10px;
  margin-bottom:16px;
  flex-wrap:wrap;
}
.controls input, .controls select{
  font-family:inherit;
  font-size:13px;
  padding:7px 10px;
  border:1px solid var(--line);
  border-radius:4px;
  background:var(--card);
  color:var(--ink);
}
.controls input{flex:1;min-width:160px;}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
  gap:14px;
}

.tag{
  position:relative;
  background:var(--card);
  border:1px solid var(--line);
  border-radius:8px;
  padding:16px 16px 14px;
}
.tag::before{
  content:'';
  position:absolute;
  top:14px;
  left:-6px;
  width:12px;
  height:12px;
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:50%;
}
.tag-top{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:8px;
}
.tag-name{font-size:15.5px;font-weight:700;line-height:1.3;}
.tag-cat{
  display:inline-block;
  margin-top:4px;
  font-size:10.5px;
  color:var(--ink-sub);
  border:1px solid var(--line);
  border-radius:3px;
  padding:1px 6px;
}
.gauge{position:relative;width:52px;height:52px;flex-shrink:0;}
.gauge svg{transform:rotate(-90deg);}
.gauge-pct{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  font-family:'JetBrains Mono',monospace;
  font-size:11px;font-weight:600;
}
.tag-mid{
  display:flex;
  align-items:baseline;
  gap:6px;
  margin:12px 0 4px;
  font-family:'JetBrains Mono',monospace;
}
.tag-mid .cur{font-size:22px;font-weight:600;}
.tag-mid .unit{font-size:12px;color:var(--ink-sub);}
.tag-mid .thresh{font-size:11px;color:var(--ink-sub);margin-left:auto;}
.status-pill{
  display:inline-block;
  font-size:10.5px;
  font-weight:500;
  padding:2px 8px;
  border-radius:3px;
  margin-bottom:10px;
}
.status-safe{background:var(--safe-bg);color:var(--safe);}
.status-warn{background:var(--warn-bg);color:var(--warn);}
.status-danger{background:var(--danger-bg);color:var(--danger);}

.tag-actions{
  display:flex;
  align-items:center;
  justify-content:space-between;
  border-top:1px dashed var(--line);
  padding-top:10px;
}
.qty-btns{display:flex;gap:6px;}
.qty-btns button{
  width:28px;height:28px;
  border:1px solid var(--line);
  background:#fff;
  border-radius:4px;
  font-size:15px;
  color:var(--ink);
  line-height:1;
}
.qty-btns button:hover{border-color:var(--ink);}
.edit-btns{display:flex;gap:10px;}
.edit-btns button{
  border:none;background:none;
  font-size:11.5px;
  color:var(--ink-sub);
  text-decoration:underline;
  padding:0;
}
.edit-btns button:hover{color:var(--stamp);}

.empty{
  text-align:center;
  padding:50px 20px;
  color:var(--ink-sub);
  font-size:13.5px;
  border:1px dashed var(--line);
  border-radius:8px;
  background:var(--card);
}

.updated{font-size:10.5px;color:var(--ink-sub);margin-top:8px;}

.scan-actions{display:flex;gap:10px;flex-wrap:wrap;}
.btn-scan{
  background:#fff;
  border:1px solid var(--ink);
  color:var(--ink);
  border-radius:4px;
  padding:9px 16px;
  font-size:13.5px;
  font-weight:500;
}
.btn-scan:hover{background:var(--paper);}
#scan-viewport{
  position:relative;
  width:100%;
  max-width:420px;
  min-height:220px;
  background:#111;
  border-radius:6px;
  overflow:hidden;
  margin-top:14px;
  display:none;
}
#scan-viewport video, #scan-viewport canvas{
  position:absolute;top:0;left:0;
  width:100%;height:100%;
  object-fit:cover;
}
#cam-video{width:100%;height:100%;object-fit:cover;}
.scan-panel-actions{
  display:flex;
  gap:10px;
  margin-top:10px;
  flex-wrap:wrap;
}
.scan-status{
  margin-top:12px;
  font-size:13px;
  line-height:1.6;
  color:var(--ink-sub);
}
.scan-result{
  margin-top:12px;
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:6px;
  padding:12px 14px;
  font-size:13px;
}
.scan-result b{font-size:14.5px;color:var(--ink);}
.scan-result .row{margin-top:4px;color:var(--ink-sub);}
.scan-result-actions{display:flex;gap:10px;margin-top:12px;}
.btn-apply{
  background:var(--ink);color:var(--paper);
  border:none;border-radius:4px;
  padding:7px 14px;font-size:12.5px;font-weight:500;
}
.btn-cancel{
  background:none;border:1px solid var(--line);
  border-radius:4px;color:var(--ink-sub);
  padding:7px 14px;font-size:12.5px;
}
.note{font-size:11.5px;color:var(--ink-sub);margin-top:10px;}

.sheet-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
.sheet-row input{
  flex:1;min-width:220px;
  font-family:inherit;font-size:13px;
  padding:8px 10px;border:1px solid var(--line);
  border-radius:4px;background:#fff;color:var(--ink);
}
#sync-status{font-size:12px;color:var(--ink-sub);margin-top:8px;}

.tabs{
  display:flex;
  gap:4px;
  border-bottom:2px solid var(--ink);
  margin-bottom:18px;
}
.tab-btn{
  background:none;
  border:none;
  padding:10px 18px;
  font-family:inherit;
  font-size:14px;
  font-weight:500;
  color:var(--ink-sub);
  border-bottom:2px solid transparent;
  margin-bottom:-2px;
}
.tab-btn.active{color:var(--ink);border-bottom-color:var(--stamp);}
.tab-btn:hover{color:var(--ink);}

.expiry-pill{
  display:inline-block;
  font-size:10.5px;
  font-weight:500;
  padding:2px 8px;
  border-radius:3px;
  margin-left:6px;
}
.expiry-ok{background:var(--card);color:var(--ink-sub);border:1px solid var(--line);}
.expiry-warn{background:var(--warn-bg);color:var(--warn);}
.expiry-danger{background:var(--danger-bg);color:var(--danger);}

.shop-row{
  display:flex;
  align-items:center;
  gap:12px;
  padding:10px 0;
  border-bottom:1px solid var(--line);
}
.shop-row:last-child{border-bottom:none;}
.shop-row .shop-name{flex:1;font-size:14px;font-weight:500;}
.shop-row .shop-sub{font-size:11.5px;color:var(--ink-sub);}
.shop-row input[type="number"]{
  width:64px;
  font-family:'JetBrains Mono',monospace;
  font-size:13px;
  padding:6px 8px;
  border:1px solid var(--line);
  border-radius:4px;
}
.shop-empty{color:var(--ink-sub);font-size:13px;padding:20px 0;text-align:center;}

.track-toggle{
  display:flex;
  gap:16px;
  margin:2px 0 14px;
  flex-wrap:wrap;
}
.track-opt{
  display:flex;
  align-items:center;
  gap:6px;
  font-size:13px;
  color:var(--ink-sub);
  cursor:pointer;
}
.track-opt input{accent-color:var(--stamp);}

input[type="range"]{
  width:100%;
  accent-color:var(--stamp);
  height:4px;
}

.pct-slider-row{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:8px;
}
.pct-slider-row input[type="range"]{flex:1;}
.pct-slider-row .pct-val{
  font-family:'JetBrains Mono',monospace;
  font-size:13px;
  font-weight:600;
  width:38px;
  text-align:right;
}
.cat-line{font-size:10.5px;color:var(--ink-sub);margin-top:4px;}

@media (max-width:640px){
  .tab-btn{padding:9px 12px;font-size:13px;flex:1;text-align:center;}
}

@media (max-width:640px){
  body{padding:16px 12px 60px;}

  header{flex-direction:column;align-items:flex-start;gap:12px;padding-bottom:12px;}
  header h1{font-size:20px;}
  .summary{align-self:stretch;justify-content:space-between;gap:8px;}
  .summary b{font-size:17px;}

  .panel{padding:14px 14px;}
  .panel h2{font-size:13px;}

  .form-grid{grid-template-columns:1fr;gap:10px;}
  .btn-add{width:100%;padding:11px 16px;font-size:14px;}

  .sheet-row{flex-direction:column;align-items:stretch;}
  .sheet-row input{min-width:0;}
  .sheet-row button{width:100%;}

  .scan-actions{flex-direction:column;}
  .scan-actions button{width:100%;}
  #scan-viewport{max-width:100%;min-height:260px;}
  .scan-panel-actions #btn-capture{width:100%;}

  .controls{flex-direction:column;}
  .controls input, .controls select{width:100%;}

  .grid{grid-template-columns:1fr;gap:12px;}
  .tag{padding:14px 14px 12px;}
  .tag-name{font-size:15px;}
  .tag-mid .cur{font-size:24px;}

  .qty-btns button{width:36px;height:36px;font-size:18px;}
  .edit-btns button{font-size:12.5px;}
}

@media (max-width:400px){
  .summary{font-size:11.5px;}
  .summary b{font-size:15px;}
}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/quagga/0.12.1/quagga.min.js"></script>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>在庫ノート</h1>
      <p>日用品・消耗品の残量チェック</p>
    </div>
    <div class="summary">
      <div class="s-total"><b id="sum-total">0</b>登録品目</div>
      <div class="s-warn"><b id="sum-warn">0</b>要注意</div>
      <div class="s-danger"><b id="sum-danger">0</b>要発注</div>
    </div>
  </header>

  <div class="panel">
    <h2>スプレッドシートと共有</h2>
    <div class="sheet-row">
      <input id="sheet-url" type="text" placeholder="Google Apps Script の Web アプリ URL を貼り付け">
      <button class="btn-scan" id="btn-sheet-connect">接続する</button>
      <button class="btn-scan" id="btn-sheet-disconnect" style="display:none;">連携を解除</button>
    </div>
    <div id="sync-status">未接続（この端末のみに保存されるローカルモードです）</div>
  </div>

  <div class="tabs">
    <button class="tab-btn active" data-tab="list">在庫一覧</button>
    <button class="tab-btn" data-tab="add">品目を追加</button>
    <button class="tab-btn" data-tab="shopping">買い物リスト</button>
  </div>

  <div class="tab-panel" id="tab-add" style="display:none;">
  <div class="panel">
    <h2>スキャンして追加</h2>
    <div class="scan-actions">
      <button class="btn-scan" id="btn-scan-barcode">バーコードを読み取る</button>
      <button class="btn-scan" id="btn-scan-photo">写真から品目を判定する</button>
      <button class="btn-scan" id="btn-scan-stop" style="display:none;">カメラを閉じる</button>
    </div>

    <div id="scan-viewport">
      <video id="cam-video" autoplay playsinline muted></video>
    </div>
    <div class="scan-panel-actions" id="photo-capture-actions" style="display:none;">
      <button class="btn-add" id="btn-capture">撮影して判定する</button>
    </div>
    <canvas id="cam-canvas" style="display:none;"></canvas>

    <div class="scan-status" id="scan-status"></div>

    <div class="scan-result" id="scan-result" style="display:none;">
      <b id="sr-name"></b>
      <div class="row" id="sr-code"></div>
      <div class="row" id="sr-category"></div>
      <div class="scan-result-actions">
        <button class="btn-apply" id="btn-apply-result">下のフォームに反映する</button>
        <button class="btn-cancel" id="btn-cancel-result">取り消す</button>
      </div>
    </div>
    <p class="note">バーコード読み取りはブラウザ内で処理されます。写真判定はAIによる推定のため、追加前に品名・数量をご確認ください。カメラの利用には許可が必要です。</p>
  </div>

  <div class="panel">
    <h2>品目を追加</h2>
    <div class="form-grid">
      <div class="field">
        <label for="in-name">品名</label>
        <input id="in-name" type="text" placeholder="例：トイレットペーパー">
      </div>
      <div class="field">
        <label for="in-cat-main">大分類</label>
        <input id="in-cat-main" type="text" placeholder="例：紙製品" list="cat-main-list">
        <datalist id="cat-main-list"></datalist>
      </div>
      <div class="field">
        <label for="in-cat-sub">小分類</label>
        <input id="in-cat-sub" type="text" placeholder="例：トイレット用品" list="cat-sub-list">
        <datalist id="cat-sub-list"></datalist>
      </div>
    </div>

    <div class="track-toggle">
      <label class="track-opt">
        <input type="radio" name="track-mode" value="count" checked>
        個数で管理
      </label>
      <label class="track-opt">
        <input type="radio" name="track-mode" value="percent">
        残量(%)で管理（袋・ボトルなど）
      </label>
    </div>

    <div class="form-grid" id="fields-count">
      <div class="field">
        <label for="in-unit">単位</label>
        <input id="in-unit" type="text" placeholder="個・本・枚など">
      </div>
      <div class="field">
        <label for="in-cur">現在の残り</label>
        <input id="in-cur" type="number" min="0" step="1" placeholder="8">
      </div>
      <div class="field">
        <label for="in-thresh">発注ライン</label>
        <input id="in-thresh" type="number" min="0" step="1" placeholder="3">
      </div>
    </div>

    <div class="form-grid" id="fields-percent" style="display:none;">
      <div class="field">
        <label for="in-cur-pct">現在の残量: <span id="in-cur-pct-val">100</span>%</label>
        <input id="in-cur-pct" type="range" min="0" max="100" step="5" value="100">
      </div>
      <div class="field">
        <label for="in-thresh-pct">発注ライン: <span id="in-thresh-pct-val">20</span>%</label>
        <input id="in-thresh-pct" type="range" min="0" max="100" step="5" value="20">
      </div>
    </div>

    <div class="form-grid">
      <div class="field">
        <label for="in-usebefore">消費期限（食品のみ・任意）</label>
        <input id="in-usebefore" type="date">
      </div>
      <div class="field">
        <label for="in-bestbefore">賞味期限（食品のみ・任意）</label>
        <input id="in-bestbefore" type="date">
      </div>
      <button class="btn-add" id="add-btn">追加する</button>
    </div>
  </div>
  </div>

  <div class="tab-panel" id="tab-list">
  <div class="controls">
    <input id="search" type="text" placeholder="品名で検索">
    <select id="filter-cat"><option value="">すべての大分類</option></select>
    <select id="sort-by">
      <option value="urgent">残り少ない順</option>
      <option value="expiry">賞味期限が近い順</option>
      <option value="name">名前順</option>
      <option value="updated">更新日順</option>
    </select>
  </div>

  <div id="grid" class="grid"></div>
  <div id="empty" class="empty" style="display:none;">
    登録された消耗品がありません。上のフォームから追加してください。
  </div>
  </div>

  <div class="tab-panel" id="tab-shopping" style="display:none;">
  <div class="panel">
    <h2>買い物リスト</h2>
    <p class="note" style="margin-top:0;">発注ライン以下の品目を自動で抽出しています。購入する数量を調整し、チェックを入れてリストをコピーできます。</p>
    <div id="shopping-list"></div>
    <div class="scan-panel-actions" style="display:flex;">
      <button class="btn-add" id="btn-copy-shopping">リストをコピーする</button>
    </div>
    <div class="scan-status" id="shopping-status"></div>
  </div>
  </div>

</div>

<script>
let items = [];
let sheetUrl = '';
let autoRefreshTimer = null;

async function loadItems(silent){
  if(sheetUrl){
    try{
      const res = await fetch(`${sheetUrl}?action=list`);
      const json = await res.json();
      items = Array.isArray(json) ? json : (json.items || []);
      setSyncStatus(`スプレッドシートと連携中（最終更新: ${new Date().toLocaleTimeString('ja-JP')}）`);
    }catch(e){
      if(!silent) setSyncStatus('スプレッドシートに接続できませんでした。URLをご確認ください。', true);
      console.error(e);
    }
  }else{
    try{
      const raw = localStorage.getItem('inventory-items');
      items = raw ? JSON.parse(raw) : [];
    }catch(e){
      items = [];
    }
  }
  render();
}

async function saveItems(){
  // ローカルモードのみで使用。スプレッドシート連携時は upsertRemote / deleteRemote を使う。
  try{
    localStorage.setItem('inventory-items', JSON.stringify(items));
  }catch(e){
    console.error('保存に失敗しました', e);
  }
}

async function persistItem(item){
  if(sheetUrl){
    try{
      await fetch(sheetUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify({ action: 'upsert', item })
      });
    }catch(e){
      setSyncStatus('スプレッドシートへの保存に失敗しました。通信環境をご確認ください。', true);
      console.error(e);
      return;
    }
    await loadItems(true);
  }else{
    await saveItems();
  }
}

async function deleteItemRemote(id){
  if(sheetUrl){
    try{
      await fetch(sheetUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify({ action: 'delete', id })
      });
    }catch(e){
      setSyncStatus('スプレッドシートへの削除反映に失敗しました。', true);
      console.error(e);
      return;
    }
    await loadItems(true);
  }else{
    items = items.filter(i => i.id !== id);
    await saveItems();
  }
}

function setSyncStatus(msg, isError){
  const el = document.getElementById('sync-status');
  if(!el) return;
  el.textContent = msg;
  el.style.color = isError ? 'var(--danger)' : 'var(--ink-sub)';
}

