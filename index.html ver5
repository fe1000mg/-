function suggestBuyQty(item){
  if(item.trackMode === 'percent') return 1;
  const t = Number(item.threshold)||0;
  const cur = Number(item.current)||0;
  const suggested = Math.round(t*2 - cur);
  return Math.max(suggested, t - cur, 1);
}

function renderShoppingList(){
  const box = document.getElementById('shopping-list');
  if(!box) return;
  const needed = items
    .filter(i => status(i) !== 'safe')
    .sort((a,b) => ratio(a) - ratio(b));

  if(needed.length === 0){
    box.innerHTML = '<div class="shop-empty">現在、購入が必要な品目はありません。</div>';
    return;
  }

  box.innerHTML = needed.map(item => {
    const isPct = item.trackMode === 'percent';
    const buyUnit = isPct ? '個' : (item.unit || '');
    return `
    <div class="shop-row" data-id="${item.id}">
      <input type="checkbox" class="shop-check" checked>
      <div style="flex:1;">
        <div class="shop-name">${escapeHtml(item.name)}</div>
