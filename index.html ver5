});

document.getElementById('btn-scan-barcode').addEventListener('click', async () => {
  await stopAllScans();
  hideResult();
  if(typeof Quagga === 'undefined'){
    setStatus('バーコード読み取りライブラリを読み込めませんでした。ネットワーク接続をご確認ください。');
    return;
  }
  scanViewport.style.display = 'block';
  camVideo.style.display = 'none';
  btnStop.style.display = 'inline-block';
  setStatus('カメラを起動しています…商品のバーコードを枠内に写してください。');

  Quagga.init({
    inputStream: {
      name: 'Live',
      type: 'LiveStream',
      target: scanViewport,
      constraints: { facingMode: 'environment' }
    },
    decoder: {
      readers: ['ean_reader', 'ean_8_reader', 'upc_reader', 'upc_e_reader', 'code_128_reader']
    },
    locate: true
  }, function(err){
    if(err){
      setStatus('カメラを起動できませんでした。ブラウザのカメラ権限をご確認ください。');
      console.error(err);
      return;
    }
    Quagga.start();
    quaggaRunning = true;
    setStatus('バーコードを読み取り中です…枠内に安定して写してください。');
  });

  Quagga.onDetected(async (data) => {
    const code = data && data.codeResult && data.codeResult.code;
    if(!code) return;
    try{ Quagga.stop(); }catch(e){}
    quaggaRunning = false;
    setStatus(`バーコードを検出しました: ${code}　商品名を検索しています…`);
    let name = '', category = '';
    try{
      const res = await fetch(`https://world.openfoodfacts.org/api/v2/product/${code}.json`);
      const json = await res.json();
      if(json && json.product){
        name = json.product.product_name_ja || json.product.product_name || '';
        category = (json.product.categories || '').split(',')[0] || '';
      }
    }catch(e){
      // 検索に失敗しても続行（手入力で対応）
    }
    setStatus(name ? '商品情報が見つかりました。内容を確認して反映してください。'
                    : '商品名を自動取得できませんでした。バーコード番号のみ反映します。品名は手入力してください。');
    showResult(name, code, category);
    scanViewport.style.display = 'none';
    btnStop.style.display = 'none';
  });
});

