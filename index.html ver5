          content: [
            { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: base64 } },
            { type: 'text', text: 'この写真の日用品・消耗品を判定してください。' }
          ]
        }]
      })
    });
    const data = await response.json();
    const textBlock = (data.content || []).find(b => b.type === 'text');
    const raw = textBlock ? textBlock.text : '';
    const clean = raw.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);

    if(!parsed.name){
      setStatus('写真から品目を判定できませんでした。品名を手入力してください。');
      hideResult();
      return;
    }
    setStatus('AIによる判定結果です。内容を確認して反映してください。');
    pendingResult = { name: parsed.name, category: parsed.category||'', unit: parsed.unit||'' };
    document.getElementById('sr-name').textContent = parsed.name;
    document.getElementById('sr-code').textContent = parsed.unit ? `推定単位: ${parsed.unit}` : '';
    document.getElementById('sr-category').textContent = parsed.category ? `推定カテゴリ: ${parsed.category}` : '';
    scanResultBox.style.display = 'block';
  }catch(e){
    console.error(e);
    setStatus('AI判定に失敗しました。ネットワーク接続をご確認のうえ、品名を手入力してください。');
  }
});

document.getElementById('btn-apply-result').addEventListener('click', () => {
  if(!pendingResult) return;
  document.getElementById('in-name').value = pendingResult.name || '';
  document.getElementById('in-cat-main').value = pendingResult.category || '';
  if(pendingResult.unit) document.getElementById('in-unit').value = pendingResult.unit;
  hideResult();
  setStatus('フォームに反映しました。数量を入力して「追加する」を押してください。');
  document.getElementById('in-cur').focus();
});

document.getElementById('btn-cancel-result').addEventListener('click', () => {
  hideResult();
  setStatus('');
});

(async function init(){
  try{
    const saved = localStorage.getItem('sheet-webapp-url');
    if(saved){
      sheetUrl = saved;
      document.getElementById('sheet-url').value = sheetUrl;
      document.getElementById('btn-sheet-disconnect').style.display = 'inline-block';
      autoRefreshTimer = setInterval(() => loadItems(true), 20000);
    }
  }catch(e){}
  await loadItems();
})();
</script>
</body>
</html>
